# =============================================
# SIFEN ENGINE - Variables de entorno
# =============================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/sifen_engine
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT para API keys internas
JWT_SECRET=cambia_esto_por_algo_muy_seguro_en_produccion
JWT_EXPIRES_IN=30d

# Encriptación de certificados (AES-256)
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CERT_ENCRYPTION_KEY=tu_clave_de_32_bytes_en_hex_aqui_64_chars

# Configuración SIFEN
SIFEN_AMBIENTE=test   # test | prod
SIFEN_TIMEOUT_MS=30000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logs
LOG_LEVEL=info
